{
  "name": "recall",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/embeddings.test.ts test/sql-guard.test.ts test/explain-annotate.test.ts test/pool.test.ts test/api-error.test.ts test/page-boot-error.test.ts test/metrics.test.ts test/admission.test.ts test/bedrock.test.ts test/trace-retry.test.ts test/observability.test.ts test/sla.test.ts",
    "test:contract": "vitest run test/api-error.test.ts",
    "test:integration": "vitest run test/*.integration.test.ts",
    "test:smoke": "playwright test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "submission:render-demo-cards": "tsx scripts/render-demo-cards.ts",
    "submission:compose-db-proof": "tsx scripts/compose-db-proof.ts",
    "submission:print-public-repo-command": "tsx scripts/print-public-repo-command.ts",
    "submission:preflight:prod": "tsx scripts/preflight-prod-deploy.ts",
    "submission:deploy:prod": "vercel deploy --prod --yes",
    "submission:check": "tsx scripts/check-submission.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx db/seed/load.ts",
    "bench": "tsx scripts/trace-bench.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1072.0",
    "@base-ui/react": "^1.6.0",
    "@smithy/node-http-handler": "^4.8.2",
    "@vercel/functions": "^3.7.1",
    "@vercel/oidc-aws-credentials-provider": "^3.1.4",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-map-gl": "^8.1.1",
    "shadcn": "^4.11.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "sharp"
    ],
    "overrides": {
      "sharp": "0.34.5"
    }
  }
}
